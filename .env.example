# SecureMed AI — Environment Configuration
# Copy this file to .env and fill in real values before running.

# LLM Provider: "ollama" (local) or "gemini" (cloud)
LLM_PROVIDER=ollama

# Gemini API key (required when LLM_PROVIDER=gemini)
#GEMINI_API_KEY=your_gemini_api_key_here

# Ollama base URL (required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# AES-256 master key — use a strong random 32+ byte string in production
SECUREMED_MASTER_KEY=change_me_to_a_strong_random_secret_key_min_32_chars
